# AiTeam - Environment Variables
# Copy this file to .env and fill in values as needed.

# Path to config file (default: ~/.ai-team-sidecar/config.json)
# SIDECAR_CONFIG=~/.ai-team-sidecar/config.json

# Data directory for SQLite DB and runtime data (default: ~/.ai-team-sidecar/data)
# DATA_DIR=~/.ai-team-sidecar/data

# Dashboard server port (default: 4041)
# PORT=4041
