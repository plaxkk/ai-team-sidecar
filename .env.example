# AiTeam - Environment Variables
# Copy this file to .env and fill in values as needed.

# Path to config file (default: ~/.aiteam/config.json)
# AITEAM_CONFIG=~/.aiteam/config.json

# Data directory for SQLite DB and runtime data (default: ~/.aiteam/data)
# DATA_DIR=~/.aiteam/data

# Dashboard server port (default: 4041)
# PORT=4041
