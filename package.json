{
  "name": "aiteam",
  "version": "0.1.0",
  "description": "Sustainable workflow flywheel for independent developers running an OPC-style AI company",
  "license": "MIT",
  "author": "AiTeam contributors",
  "repository": {
    "type": "git",
    "url": "https://github.com/plaxkk/AiTeam.git"
  },
  "keywords": [
    "ai",
    "claude-code",
    "codex",
    "developer-tools",
    "workflow",
    "project-management",
    "dashboard"
  ],
  "private": false,
  "type": "module",
  "scripts": {
    "build": "npm run build:dashboard && tsc",
    "build:dashboard": "esbuild src/dashboard/public/app.jsx --jsx-factory=React.createElement --jsx-fragment=React.Fragment --format=iife --target=es2018 --minify --outfile=src/dashboard/public/app.js",
    "setup": "node --loader ts-node/esm bin/setup.ts",
    "install:claude-hooks": "node --loader ts-node/esm bin/install-claude-hooks.ts",
    "doctor": "node --loader ts-node/esm bin/doctor.ts",
    "daemon": "node --loader ts-node/esm src/collector/daemon.ts",
    "dashboard": "node --loader ts-node/esm src/dashboard/server.ts",
    "start": "bash bin/start.sh",
    "backfill": "node --loader ts-node/esm bin/backfill.ts",
    "backfill:claude": "node --loader ts-node/esm bin/backfill.ts",
    "sync:codex": "node --loader ts-node/esm bin/sync-codex.ts",
    "checkpoint": "node --loader ts-node/esm bin/checkpoint.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "better-sqlite3": "^11.7.0",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "esbuild": "^0.28.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "vitest": "^4.1.6"
  }
}
